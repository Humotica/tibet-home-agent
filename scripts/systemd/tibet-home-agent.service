[Unit]
Description=TIBET Home Agent — BYOK Mode 3 relay (I-Poll → local AI CLI)
Documentation=https://github.com/jaspertvdm/tibet-home-agent
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=root
EnvironmentFile=/etc/default/tibet-home-agent
ExecStart=/usr/local/bin/tibet-home-agent
Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=tibet-home-agent

[Install]
WantedBy=multi-user.target
